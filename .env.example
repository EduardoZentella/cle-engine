# Copy this file to .env and update values for your local environment.
# Do not commit .env to source control.

# Vault dev root token used by vault + vault-init services.
VAULT_DEV_ROOT_TOKEN_ID=your-vault-dev-root-token-id

# Optional overrides for non-DB secrets written into Vault by vault-init.
FRONTEND_API_URL=http://localhost:8000
ADMIN_API_URL=http://backend:8000

# Gemini API configuration for embeddings and LLM generation
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Optional: embedding dimension (default: 384 for gemini-embedding-2)
EMBEDDING_DIMENSION=384

# Database configuration
DATABASE_URL=postgresql://admin:local_dev@localhost:5432/cle_engine
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# Postgres container defaults
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-your-postgres-password
POSTGRES_DB=cle_engine
