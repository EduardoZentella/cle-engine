# Copy this file to .env and update values for your local environment.
# Do not commit .env to source control.

# Vault dev root token used by vault + vault-init services.
VAULT_DEV_ROOT_TOKEN_ID=replace-with-strong-dev-root-token

# Optional overrides for non-DB secrets written into Vault by vault-init.
FRONTEND_API_URL=http://localhost:8000
ADMIN_API_URL=http://backend:8000

# LLM embedding configuration for backend (stored in Vault).
LLM_API_KEY=replace-with-your-provider-key
# Optional: keep default unless your provider uses a different model name.
LLM_EMBEDDING_MODEL=text-embedding-3-small
# Optional: OpenAI-compatible embeddings endpoint.
LLM_EMBEDDING_URL=https://api.openai.com/v1/embeddings
# Optional: set to hash or sentence_transformers to bypass LLM API embeddings.
BACKEND_EMBEDDING_BACKEND=llm_api

# Optional: recommendation/practice draft provider backend.
BACKEND_INTELLIGENCE_BACKEND=generic_http

# Optional: OpenAI-compatible completion model settings.
# For Gemini, examples are:
# LLM_COMPLETION_MODEL=gemini-2.0-flash
# LLM_COMPLETION_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
LLM_COMPLETION_MODEL=gpt-4o-mini
LLM_COMPLETION_URL=https://api.openai.com/v1/chat/completions

# Optional pretrained final reranker artifact location.
# If files are missing, backend falls back automatically to embedding similarity reranking.
FINAL_RERANKER_MODEL_DIR=models/final_reranker
FINAL_RERANKER_MANIFEST_FILE=manifest.json

# Optional DB init values used by Postgres container.
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_DB=cle_engine
